# ============================================
# 欣琪国际货运官网 - 环境变量配置模板
# ============================================

# -------------------------------------------
# 数据库配置 (PostgreSQL)
# -------------------------------------------
# 方式一：使用连接字符串（推荐）
DATABASE_URL=postgresql://postgres:your-password@your-db-host.volcengine.com:5432/xinqi_freight?sslmode=require

# 方式二：使用单独参数（如果没有 DATABASE_URL，会从这些参数构建连接）
# DATABASE_HOST=your-db-host.volcengine.com
# DATABASE_PORT=5432
# DATABASE_NAME=xinqi_freight
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-database-password

# 注意：
# - 如果同时配置了 DATABASE_URL 和单独参数，优先使用 DATABASE_URL
# - 生产环境建议使用 DATABASE_URL 连接字符串
# - sslmode=require 是必需的，确保 SSL 连接
# - 如果密码包含特殊字符，需要进行 URL 编码

# -------------------------------------------
# 对象存储配置
# -------------------------------------------

# 存储类型: tos (火山引擎TOS直连) 或 coze (Coze内置存储)
STORAGE_TYPE=tos

# 火山引擎 TOS 配置 (当 STORAGE_TYPE=tos 时需要)
TOS_ACCESS_KEY=your-tos-access-key
TOS_SECRET_KEY=your-tos-secret-key
TOS_REGION=cn-beijing
TOS_ENDPOINT=https://tos-cn-beijing.volces.com
TOS_BUCKET=your-bucket-name

# Coze 内置存储配置 (当 STORAGE_TYPE=coze 时需要)
# 无需额外配置，自动使用 Coze 环境

# -------------------------------------------
# 管理员配置
# -------------------------------------------
# 管理员登录密码 (可选，用于首次初始化)
ADMIN_PASSWORD=admin123

# -------------------------------------------
# 服务配置
# -------------------------------------------
# Node 环境
NODE_ENV=development

# 服务端口 (默认 5000)
PORT=5000
